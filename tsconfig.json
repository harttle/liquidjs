{
  "compilerOptions": {
    "target": "ES2020",
    "module":"ES2020",
    "lib": ["ES2020", "dom"],
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "declaration": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true
  },
  "all": true,
  "exclude": [ "node_modules", "dist", "demo", "test" ]
}
